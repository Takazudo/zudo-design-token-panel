---
import DocLayout from "@/layouts/doc-layout.astro";
import { settings } from "@/config/settings";
import { withBase } from "@/utils/base";
import { defaultLocale } from "@/config/i18n";
import FeatureCard from "@/components/feature-card.astro";

const logoUrl = withBase("/img/logo.svg");
const githubUrl = "https://github.com/takazudo/zudo-design-token-panel";
const gettingStartedHref = withBase("/docs/getting-started");
const examplesBaseUrl =
  "https://github.com/Takazudo/zudo-design-token-panel/tree/main/examples";
const astroExampleUrl = `${examplesBaseUrl}/astro`;
const viteReactExampleUrl = `${examplesBaseUrl}/vite-react`;
const nextExampleUrl = `${examplesBaseUrl}/next`;
---

<DocLayout title={settings.siteName} lang={defaultLocale} hideSidebar hideToc>
  <!-- Hero: logo left, title+desc+links right, block centered -->
  <div class="flex justify-center mb-vsp-xl">
    <div
      class="flex flex-col items-center text-center gap-hsp-md lg:flex-row lg:text-left lg:gap-hsp-xl"
    >
      <div
        class="w-[60%] aspect-square lg:h-[10.5rem] lg:w-[10.5rem] bg-fg shrink-0"
        style={`-webkit-mask: url(${logoUrl}) center/contain no-repeat; mask: url(${logoUrl}) center/contain no-repeat;`}
        aria-hidden="true"
      >
      </div>
      <div>
        <h1 class="text-heading font-bold mb-vsp-2xs">{settings.siteName}</h1>
        <p class="text-muted text-small mb-vsp-sm max-w-[40rem]">
          A Preact-based live design-token tweak panel and companion Node bin
          server. Adjust CSS custom properties in the browser and persist the
          changes back to your source files through the apply pipeline.
        </p>
        <div
          class="flex flex-wrap items-center justify-center lg:justify-start gap-hsp-md text-small"
        >
          <a
            href={gettingStartedHref}
            class="text-fg underline hover:text-accent"
          >
            Getting Started
          </a>
          <span class="text-muted">/</span>
          <a
            href={githubUrl}
            class="inline-flex items-center gap-[0.3em] text-fg underline hover:text-accent"
            target="_blank"
            rel="noopener noreferrer"
            ><svg
              viewBox="0 0 16 16"
              aria-hidden="true"
              class="w-[1em] h-[1em] shrink-0"
              ><path
                fill="currentColor"
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
              ></path></svg
            >GitHub</a
          >
          <span class="text-muted">/</span>
          <a
            href="#features"
            class="text-fg underline hover:text-accent">Features</a
          >
        </div>
      </div>
    </div>
  </div>

  <!-- Intro paragraph -->
  <section class="mb-vsp-xl max-w-[52rem] mx-auto text-center">
    <p class="text-body text-muted">
      zudo-design-token-panel is a standalone OSS port of the design-token-panel
      originally built inside zmodular. It is host-config-driven, so the same
      panel works in Astro, Vite + React, or Next.js — your app supplies a
      TokenManifest and ColorClusterConfig, and the panel handles the rest.
      MIT licensed.
    </p>
  </section>

  <!-- Feature cards -->
  <section id="features" class="mb-vsp-xl">
    <h2 class="text-subheading font-bold mb-vsp-md text-center">
      What it does
    </h2>
    <div
      class="grid gap-hsp-lg sm:grid-cols-2 lg:grid-cols-2"
    >
      <FeatureCard title="Live token tweaking">
        Drag sliders and color pickers in a docked panel to tune CSS custom
        properties — colors, spacing, typography — and watch your running app
        update in real time.
      </FeatureCard>
      <FeatureCard title="Apply to source">
        When a tweak feels right, the companion Node bin server rewrites the
        underlying token files atomically so your changes land in source
        control instead of vanishing on reload.
      </FeatureCard>
      <FeatureCard title="Framework-agnostic">
        Drop the panel into Astro, Vite + React, or Next.js. The runtime is
        plain Preact and the apply pipeline is a small Node binary, so it
        slots into whatever stack your product team already uses.
      </FeatureCard>
      <FeatureCard title="Host-config-driven">
        Consumers supply their own TokenManifest and ColorClusterConfig. The
        panel infers the right controls from your tokens — no hard-coded
        assumptions about your design system baked into the tool.
      </FeatureCard>
    </div>
  </section>

  <!-- Link cards -->
  <section class="mb-vsp-xl">
    <h2 class="text-subheading font-bold mb-vsp-md text-center">
      Explore
    </h2>
    <div class="grid gap-hsp-lg sm:grid-cols-3">
      <FeatureCard title="Getting Started" href={gettingStartedHref}>
        Install the panel, wire up your TokenManifest, and start tweaking
        tokens against your local dev server.
      </FeatureCard>
      <FeatureCard title="Example Apps" href="#example-apps">
        Reference integrations across Astro, Vite + React, and Next.js. The
        example apps live alongside the panel package on GitHub.
      </FeatureCard>
      <FeatureCard title="GitHub" href={githubUrl} external>
        Source code, issues, and release notes for zudo-design-token-panel.
      </FeatureCard>
    </div>
  </section>

  <!-- Example apps -->
  <section id="example-apps" class="mb-vsp-xl">
    <h2 class="text-subheading font-bold mb-vsp-md text-center">
      Example Apps
    </h2>
    <p class="text-muted text-small mb-vsp-md text-center max-w-[40rem] mx-auto">
      Reference integrations across three popular stacks. The links point at
      the <code>examples/</code> directory in the GitHub repo. The example apps
      are coming soon — these links may 404 until the examples land.
    </p>
    <div class="grid gap-hsp-lg sm:grid-cols-3">
      <FeatureCard title="Astro" href={astroExampleUrl} external>
        Drop the panel into an Astro site. Demonstrates host-config wiring
        with an Astro dev server and the bin apply pipeline.
      </FeatureCard>
      <FeatureCard title="Vite + React" href={viteReactExampleUrl} external>
        Use the panel from a Vite + React app. Shows how the Preact runtime
        coexists with React via the compat shim.
      </FeatureCard>
      <FeatureCard title="Next.js" href={nextExampleUrl} external>
        Wire the panel into a Next.js app router project, including the bin
        server side-by-side with the Next dev server.
      </FeatureCard>
    </div>
  </section>
</DocLayout>
